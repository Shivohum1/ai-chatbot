# Groq LLM
GROQ_API_KEY=your_groq_api_key

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=knowledge_chunks

# Bootstrap API keys on startup (user_id:plaintext_key,user_id2:plaintext_key2)
BOOTSTRAP_API_KEYS=demo-user:change-me-to-a-long-random-secret

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000

# Models and RAG
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHAT_MODEL_NAME=llama-3.3-70b-versatile
MAX_HISTORY_MESSAGES=12
MAX_MESSAGE_LENGTH=4000
RAG_TOP_K=4
CHUNK_SIZE_DEFAULT=800
CHUNK_OVERLAP_DEFAULT=120

# Upload limits
MAX_UPLOAD_BYTES=10485760
MAX_UPLOAD_FILES=5

# Rate limits
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_INGEST=10/minute

# Arize telemetry (optional)
ARIZE_SPACE_ID=
ARIZE_API_KEY=
